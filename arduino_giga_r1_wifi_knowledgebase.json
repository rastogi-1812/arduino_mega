  "code_examples": {
    "blink": "void setup() { pinMode(LED_BUILTIN, OUTPUT); }\nvoid loop() { digitalWrite(LED_BUILTIN, LOW); delay(1000); digitalWrite(LED_BUILTIN, HIGH); delay(1000); }",
    "analog_read": "void setup() { Serial.begin(9600); }\nvoid loop() { int val = analogRead(A0); Serial.println(val); delay(100); }",
    "dac_write": "void setup() { analogWriteResolution(12); }\nvoid loop() { analogWrite(A12, 2048); }",
    "serial_uart": "void setup() { Serial.begin(9600); Serial1.begin(9600); }\nvoid loop() { if(Serial1.available()) { Serial.write(Serial1.read()); } }",
    "i2c_scan": "#include <Wire.h>\nvoid setup() { Serial.begin(9600); Wire.begin(); }\nvoid loop() { for(int i=1;i<127;i++) { Wire.beginTransmission(i); if(Wire.endTransmission()==0) { Serial.print(\"Found: 0x\"); Serial.println(i,HEX); } } delay(5000); }",
    "wifi_connect": "#include <WiFi.h>\nchar ssid[]=\"SSID\"; char pass[]=\"PASS\";\nvoid setup() { Serial.begin(9600); while(WiFi.status()!=WL_CONNECTED) { WiFi.begin(ssid,pass); delay(10000); } Serial.println(WiFi.localIP()); }",
    "sdram_usage": "#include \"SDRAM.h\"\nvoid setup() { SDRAM.begin(); uint8_t* arr=(uint8_t*)SDRAM.malloc(7*1024*1024); for(int i=0;i<128;i++) arr[i]=i; SDRAM.free(arr); }",
    "can_bus": "#include \"CAN.h\"\nmbed::CAN can1(PB_5,PB_13);\nvoid setup() { Serial.begin(115200); can1.frequency(1000000); }\nvoid loop() { uint8_t c=0; can1.write(mbed::CANMessage(1337,&c,1)); delay(1000); }",
    "interrupt": "volatile byte state=LOW;\nvoid setup() { pinMode(13,OUTPUT); pinMode(2,INPUT_PULLUP); attachInterrupt(digitalPinToInterrupt(2),blink,CHANGE); }\nvoid loop() { digitalWrite(13,state); }\nvoid blink() { state=!state; }",
    "boot0_read": "void setup() { Serial.begin(9600); }\nvoid loop() { Serial.println(digitalRead(PC_13)); delay(100); }"
  },
